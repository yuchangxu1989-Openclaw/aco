{
  "id": "aco-async-discipline-guard",
  "name": "ACO Async Discipline Guard",
  "version": "1.1.0",
  "main": "index.js",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "maxBlockingTimeoutMs": {
        "type": "number"
      },
      "blockingActions": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "llmJudgement": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "timeoutMs": {
            "type": "number"
          }
        }
      },
      "degradedRecoveryWindowMs": {
        "type": "number"
      }
    }
  }
}
